{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "page_slug": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "sections": {
      "type": "dynamiczone",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "components": [
        "sections.testimonials",
        "sections.qr-code",
        "sections.location",
        "sections.hero",
        "sections.food-menu",
        "sections.features",
        "sections.booking",
        "sections.about"
      ]
    },
    "website": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::website.website",
      "inversedBy": "pages"
    }
  }
}
