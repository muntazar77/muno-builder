{
  "kind": "collectionType",
  "collectionName": "websites",
  "info": {
    "singularName": "website",
    "pluralName": "websites",
    "displayName": "Website"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "client_name": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "page_sections": {
      "type": "dynamiczone",
      "components": [
        "sections.hero",
        "sections.features",
        "sections.testimonials",
        "sections.location",
        "sections.about",
        "sections.food-menu",
        "sections.qr-code",
        "sections.booking"
      ]
    },
    "dishes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::dish.dish",
      "inversedBy": "websites"
    },
    "template_name": {
      "type": "enumeration",
      "enum": [
        "luxury",
        "light"
      ]
    },
    "bookings": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::booking.booking",
      "mappedBy": "websites"
    },
    "footer_link_groups": {
      "type": "component",
      "component": "shared.link-group",
      "repeatable": true
    },
    "header_links": {
      "type": "component",
      "component": "shared.link-item",
      "repeatable": true
    },
    "pages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::page.page",
      "mappedBy": "website"
    }
  }
}
