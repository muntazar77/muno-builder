---
// src/layouts/TenantLayout.astro
interface Props {
  title: string;
  templateName: string;
}

const { title, templateName } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <slot name="head" />
</head>
<body class={`antialiased template-${templateName}`}>
    <slot />
</body>
</html>
