---
interface Props {
  title: string;
  description?: string;
}

import '../styles/global.css';


---

<!doctype html>
<html lang="en" data-theme="light" dir="ltr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0"
    />
    


    <!-- Simple Theme Initialization -->
    <script is:inline>
      // Simple theme initialization - starts with light theme
      // Theme customizer will handle switching after page load
      (function () {
        try {
          // Check if user has a saved theme preference
          const savedTheme = localStorage.getItem('selected-theme');
          const savedDirection = localStorage.getItem('layout-direction') || 'ltr';

          // Apply saved theme or default to light
          const theme = savedTheme || 'light';

          document.documentElement.setAttribute('data-theme', theme);
          document.documentElement.setAttribute('dir', savedDirection);
        } catch (e) {
          // Fallback to light theme
          document.documentElement.setAttribute('data-theme', 'light');
          document.documentElement.setAttribute('dir', 'ltr');
        }
      })();
    </script>
  </head>
  <body>
	<slot />
  </body>
</html>