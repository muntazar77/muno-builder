---
// src/components/templates/restaurant-light/Hero.astro
const { title, description, background_image, cta_button } = Astro.props;
const STRAPI_BASE_URL = import.meta.env.PUBLIC_STRAPI_URL || 'http://localhost:1337';
// استخراج الصورة والزر ديناميكياً
const imgUrl = background_image?.url 
  ? `${STRAPI_BASE_URL}${background_image.url}` 
  : "/fallback2.png";

const buttonText = cta_button?.text || "Speisekarte ansehen";
const buttonUrl = cta_button?.url || "#menu";
---
<section class="relative w-full bg-gradient-to-b from-amber-50/60 to-white pt-32 pb-20 px-6 overflow-hidden flex items-center min-h-[85vh]">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center w-full">
    
    <div class="lg:col-span-7 space-y-6 text-center lg:text-left">
      <span class="inline-block px-3 py-1 bg-orange-100 text-orange-700 rounded-full text-xs font-black uppercase">🔥 Frisch zubereitet</span>
      <h1 class="text-4xl sm:text-6xl font-black text-gray-950 leading-tight tracking-tight">{title}</h1>
      <p class="text-gray-600 text-base md:text-lg leading-relaxed max-w-xl mx-auto lg:mx-0">{description}</p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
        <!-- زر ديناميكي -->
        <a href={buttonUrl} class="px-8 py-4 bg-orange-500 text-white text-sm font-bold uppercase rounded-2xl shadow-lg hover:bg-orange-600 transition-all">
          {buttonText}
        </a>
      </div>
    </div>
    
    <div class="lg:col-span-5 flex justify-center">
      <!-- الصورة الجانبية الديناميكية المرفوعة من العميل -->
      <img src={imgUrl} alt={title} class="w-full max-w-[400px] aspect-square rounded-3xl object-cover shadow-2xl border-8 border-white bg-white rotate-2 hover:rotate-0 transition-transform duration-500" />
    </div>

  </div>
</section>
