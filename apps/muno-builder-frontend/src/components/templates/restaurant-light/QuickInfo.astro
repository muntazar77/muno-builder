---
// src/components/templates/restaurant-light/QuickInfo.astro
---
<section class="py-12 bg-white px-6">
  <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-6">
    <div class="p-6 bg-gray-50 rounded-2xl border border-gray-100 flex items-center gap-4">
      <span class="text-3xl">📞</span>
      <div>
        <div class="text-xs text-gray-400 font-bold uppercase">Rufen Sie uns an</div>
        <p class="text-gray-800 font-bold text-sm mt-0.5">+49 30 123456</p>
      </div>
    </div>
    <div class="p-6 bg-gray-50 rounded-2xl border border-gray-100 flex items-center gap-4">
      <span class="text-3xl">📍</span>
      <div>
        <div class="text-xs text-gray-400 font-bold uppercase">Unser Standort</div>
        <p class="text-gray-800 font-bold text-sm mt-0.5">Berliner Str. 45, Berlin</p>
      </div>
    </div>
    <div class="p-6 bg-gray-50 rounded-2xl border border-gray-100 flex items-center gap-4">
      <span class="text-3xl">⏰</span>
      <div>
        <div class="text-xs text-gray-400 font-bold uppercase">Öffnungszeiten</div>
        <p class="text-gray-800 font-bold text-sm mt-0.5">Di - So: 12:00 - 22:00 Uhr</p>
      </div>
    </div>
  </div>
</section>
