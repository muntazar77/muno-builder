---
// src/components/templates/restaurant-light/Footer.astro
const { clientName = "Burger & Bites" } = Astro.props;
---
<footer class="bg-gray-50 border-t border-gray-100 text-gray-500 text-sm">
  <div class="max-w-6xl mx-auto px-6 py-12 space-y-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6 border-b border-gray-200 pb-8">
      <a href="#" class="text-xl font-black text-gray-900 tracking-tight no-underline">🍔 {clientName}</a>
      <div class="flex gap-6">
        <a href="#" class="text-gray-500 hover:text-orange-500 no-underline text-xs font-bold uppercase">Impressum</a>
        <a href="#" class="text-gray-500 hover:text-orange-500 no-underline text-xs font-bold uppercase">Datenschutz</a>
      </div>
    </div>
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-400">
      <p>&copy; 2026 {clientName}. Alle Rechte vorbehalten.</p>
      <p class="font-medium text-gray-500">Powered by Mono Builder</p>
    </div>
  </div>
</footer>
