---
interface HeroButton {
  text?: string | null;
  label?: string | null;
  title?: string | null;
  url?: string | null;
  href?: string | null;
}

interface Props {
  title?: string | null;
  description?: string | null;
  hero_title?: string | null;
  hero_description?: string | null;
  eyebrow?: string | null;
  badge?: string | null;
  background_image?: { url?: string | null } | null;
  image?: { url?: string | null } | null;
  hero_image?: { url?: string | null } | null;
  cta_button?: HeroButton | null;
  primary_action?: HeroButton | null;
}

const safeText = (value: unknown, fallback: string): string => {
  if (typeof value === 'string' && value.trim()) {
    return value.trim();
  }

  return fallback;
};

const {
  title,
  description,
  hero_title,
  hero_description,
  eyebrow,
  badge,
  background_image,
  image,
  hero_image,
  cta_button,
  primary_action
} = Astro.props as Props;

const strapiBaseUrl = import.meta.env.PUBLIC_STRAPI_URL || 'http://localhost:1337';
const heroHeading = safeText(hero_title ?? title, 'Strategic guidance for complex growth');
const heroBody = safeText(hero_description ?? description, 'Partner with a trusted team that helps offices, clinics, and legal practices modernize the way they connect with clients.');
const heroEyebrow = safeText(eyebrow ?? badge, 'Multi-vertical advisory');
const heroImage = background_image?.url ?? image?.url ?? hero_image?.url;
const heroImageUrl = heroImage ? `${strapiBaseUrl}${heroImage}` : null;
const action = cta_button ?? primary_action;
const actionLabel = safeText(action?.text ?? action?.label ?? action?.title, 'Book a consultation');
const actionHref = safeText(action?.url ?? action?.href, '#contact');
---
<section class="relative overflow-hidden bg-[color:var(--brand-primary)] text-white">
  <div class="absolute inset-0">
    {heroImageUrl ? (
      <img src={heroImageUrl} alt={heroHeading} class="h-full w-full object-cover opacity-30" />
    ) : null}
    <div class="absolute inset-0 bg-gradient-to-r from-[color:var(--brand-primary)] via-[color:var(--brand-primary)]/90 to-[color:var(--brand-secondary)]/80" />
  </div>

  <div class="relative mx-auto flex min-h-[80vh] max-w-7xl items-center px-6 py-24 lg:px-8 lg:py-32">
    <div class="max-w-3xl space-y-8">
      <div class="inline-flex items-center rounded-full border border-white/15 bg-white/10 px-4 py-2 text-sm font-medium tracking-[0.24em] uppercase text-white/90 backdrop-blur">
        {heroEyebrow}
      </div>

      <div class="space-y-5">
        <h1 class="max-w-3xl text-4xl font-semibold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
          {heroHeading}
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-white/80 sm:text-xl">
          {heroBody}
        </p>
      </div>

      <div class="flex flex-col gap-4 sm:flex-row">
        <a
          href={actionHref}
          class="rounded-full bg-[color:var(--brand-accent)] px-7 py-3.5 text-center text-sm font-semibold uppercase tracking-[0.24em] text-[color:var(--brand-primary)] transition-opacity duration-200 hover:opacity-90"
        >
          {actionLabel}
        </a>
        <a
          href="#services"
          class="rounded-full border border-white/20 px-7 py-3.5 text-center text-sm font-semibold uppercase tracking-[0.24em] text-white transition-colors duration-200 hover:bg-white/10"
        >
          Explore services
        </a>
      </div>
    </div>
  </div>
</section>
