---
// src/components/templates/restaurant-dark/Footer.astro
// استقبال اسم المطعم ومجموعات الروابط القادمة ديناميكياً من صفحة [slug].astro
const { clientName, address, footer_link_groups } = Astro.props;
---
<footer class="bg-[#080605] border-t border-[#F2EDE4]/5 text-[#F2EDE4]/55">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-16 lg:py-20">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-14 lg:gap-20">
      
      <!-- براند المطعم -->
      <div class="lg:col-span-5 space-y-4">
        <a href="#" class="block font-serif leading-none">
          <span class="text-xl font-medium tracking-tight text-[#F2EDE4]">{clientName}</span>
        </a>
        <p class="text-xs font-light leading-relaxed max-w-[34ch]">
          Gehobene Küche im Herzen der Stadt. Drei Michelin-Sterne.
        </p>
      </div>

      <!-- 💡 السحر البرمجي: تكرار ورسم أعمدة الروابط ديناميكياً بناءً على ما أنشأه العميل في Strapi -->
      <div class="lg:col-span-7 grid grid-cols-2 sm:grid-cols-3 gap-8">
        {footer_link_groups && footer_link_groups.map((group: any) => (
          <div>
            <!-- عنوان العمود (مثل: Navigation أو Rechtliches) -->
            <h4 class="text-[0.55rem] tracking-[0.26em] uppercase text-[#F2EDE4]/35 mb-4 font-semibold">
              {group.group_title}
            </h4>
            <ul class="space-y-3 list-none p-0">
              {group.links && group.links.map((link: any) => (
                <li>
                  <a href={link.url} class="text-[#F2EDE4]/45 text-xs font-light hover:text-[#F2EDE4] transition-colors no-underline">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

    </div>

    <!-- الشريط السفلي وحفظ الحقوق -->
    <div class="mt-12 pt-6 border-t border-[#F2EDE4]/5 text-xs text-[#F2EDE4]/20 flex justify-between items-center">
      <p>&copy; 2026 {clientName}. Alle Rechte vorbehalten.</p>
      <p class="font-medium">Powered by Mono Builder</p>
    </div>

  </div>
</footer>
