---
// src/components/templates/restaurant-dark/Footer.astro
const { clientName = "Mono Client", address = "", footer_link_groups = [], templateName = "luxury" } = Astro.props;

const isLuxury = templateName === 'luxury';
const footerBg = isLuxury ? 'bg-[#080605] text-[#F2EDE4]/55' : 'bg-gray-50 text-gray-600';
const titleColor = isLuxury ? 'text-[#F2EDE4]' : 'text-gray-900';
const labelColor = isLuxury ? 'text-[#F2EDE4]/45 hover:text-[#F2EDE4]' : 'text-gray-500 hover:text-brand-primary';
const borderColor = isLuxury ? 'border-[#F2EDE4]/5' : 'border-gray-200';
---
<footer class={`border-t list-none transition-colors duration-300 ${footerBg} ${borderColor}`}>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-16 lg:py-20">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-14 lg:gap-20">
      
      <!-- براند المستأجر -->
      <div class="lg:col-span-5 space-y-4">
        <a href="#" class="block font-serif leading-none no-underline">
          <span class={`text-xl font-medium tracking-tight ${titleColor}`}>{clientName}</span>
        </a>
        <p class="text-xs font-light leading-relaxed max-w-[34ch] opacity-80">
          {address || "Gehobene Küche im Herzen der Stadt. Bereitgestellt von Mono Builder Plattform."}
        </p>
      </div>

      <!-- 💡 السحر البرمجي المصلح: فك تعبئة مصفوفات المجموعات والروابط المستخرجة من العمق بدقة -->
      <div class="lg:col-span-7 grid grid-cols-2 sm:grid-cols-3 gap-8">
        {footer_link_groups && footer_link_groups.map((group: any) => (
          <div>
            <!-- عنوان العمود المستخرج من الباكيند (مثل: Rechtliches المعروض في صورتك) -->
            <h4 class="text-[0.55rem] tracking-[0.26em] uppercase text-[#C8973A] mb-4 font-semibold">
              {group.group_title}
            </h4>
            <ul class="space-y-3 list-none p-0 m-0">
              {/* 💡 قراءة حقل الـ links الداخلي الموضح في صورتك بنجاح */}
              {group.links && group.links.map((link: any) => (
                <li>
                  <a 
                    href={link.url || "#"} 
                    class={`text-xs font-light transition-colors no-underline block ${labelColor}`}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

    </div>

    <!-- الشريط السفلي وحفظ الحقوق -->
    <div class={`mt-12 pt-6 border-t text-xs flex justify-between items-center opacity-40 ${borderColor}`}>
      <p>&copy; 2026 {clientName}. Alle Rechte vorbehalten.</p>
      <p class="font-medium">Powered by Mono Builder</p>
    </div>

  </div>
</footer>
