---
// src/components/LocationContact.astro
---
<section id="contact" class="py-28 lg:py-36 bg-[#0E0B09]">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    
    <div class="flex items-center gap-4 mb-14">
      <div class="h-px w-8 bg-[#C8973A]" />
      <span class="uppercase tracking-widest text-[#C8973A] text-[0.58rem] tracking-[0.3em] font-medium">
        Standort & Kontakt
      </span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-14 lg:gap-20">
      
      <!-- التفاصيل وبيانات التواصل / Info Column -->
      <div class="lg:col-span-5 space-y-10">
        <div>
          <h2 class="text-[#F2EDE4] mb-6 font-serif font-light text-[clamp(2.2rem,4.5vw,4rem)] leading-none tracking-tight">
            Finden Sie<br />
            <span class="italic font-semibold text-[#C8973A]">zu uns.</span>
          </h2>
          <p class="text-[#F2EDE4]/45 text-sm font-light leading-relaxed">
            Unser Restaurant befindet sich in einer ruhigen, aber zentralen Lage im Herzen der Stadt, untergebracht in einem sorgfältig restaurierten Gebäude.
          </p>
        </div>

        <div class="space-y-6">
          <!-- Adresse -->
          <div class="flex gap-4">
            <div class="text-[#C8973A]/60 mt-0.5 shrink-0">
              <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
            </div>
            <div>
              <div class="text-[0.55rem] tracking-[0.24em] uppercase text-[#F2EDE4]/35 mb-1">Adresse</div>
              <p class="text-[#F2EDE4]/70 text-sm font-light leading-relaxed whitespace-pre-line">Hauptstraße 14, 1. OG\n10117 Berlin, Deutschland</p>
            </div>
          </div>

          <!-- Kontakt -->
          <div class="flex gap-4">
            <div class="text-[#C8973A]/60 mt-0.5 shrink-0">
              <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.802-5.188-4.166-7-7l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
            </div>
            <div>
              <div class="text-[0.55rem] tracking-[0.24em] uppercase text-[#F2EDE4]/35 mb-1">E-Mail & Telefon</div>
              <a href="tel:+49123456789" class="block text-[#F2EDE4]/70 text-sm font-light hover:text-[#C8973A] transition-colors">++49 123 456 789</a>
              <a href="mailto:info@restaurant.de" class="block text-[#F2EDE4]/70 text-sm font-light hover:text-[#C8973A] transition-colors mt-0.5">info@restaurant.de</a>
            </div>
          </div>
        </div>

        <!-- خريطة توضيحية / Map Placeholder -->
        <div class="relative overflow-hidden h-[200px] bg-[#161310] border border-[#F2EDE4]/7 flex flex-col items-center justify-center gap-2">
          <span class="text-[0.7rem] text-[#F2EDE4]/35 tracking-[0.12em] uppercase">Berlin, Deutschland</span>
          <a href="https://google.com" target="_blank" rel="noreferrer" class="mt-2 px-5 py-2 border border-[#C8973A]/30 text-[#C8973A] text-[0.55rem] tracking-widest uppercase hover:bg-[#C8973A]/5 transition-all duration-200">
            In Maps öffnen
          </a>
        </div>
      </div>

      <!-- نموذج إرسال رسالة سريعة / Right: Message form -->
      <div class="lg:col-span-7">
        <h3 class="mb-8 font-serif text-2xl font-light text-[#F2EDE4] tracking-tight">Schreiben Sie uns</h3>
        <form class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input type="text" required placeholder="Name" class="w-full bg-[#161310] border border-[#F2EDE4]/10 px-4 py-3.5 text-sm text-[#F2EDE4] focus:outline-none focus:border-[#C8973A] transition-colors" />
            <input type="email" required placeholder="E-Mail-Adresse" class="w-full bg-[#161310] border border-[#F2EDE4]/10 px-4 py-3.5 text-sm text-[#F2EDE4] focus:outline-none focus:border-[#C8973A] transition-colors" />
          </div>
          <input type="text" required placeholder="Betreff" class="w-full bg-[#161310] border border-[#F2EDE4]/10 px-4 py-3.5 text-sm text-[#F2EDE4] focus:outline-none focus:border-[#C8973A] transition-colors" />
          <textarea required rows="6" placeholder="Wie können wir Ihnen helfen?" class="w-full bg-[#161310] border border-[#F2EDE4]/10 px-4 py-3.5 text-sm text-[#F2EDE4] focus:outline-none focus:border-[#C8973A] transition-colors resize-none"></textarea>
          <button type="submit" class="w-full py-4 border border-[#C8973A] text-[#C8973A] text-[0.68rem] tracking-widest uppercase font-semibold hover:bg-[#C8973A] hover:text-[#0C0A08] transition-all duration-300 cursor-pointer">Nachricht senden</button>
        </form>
      </div>

    </div>
  </div>
</section>
