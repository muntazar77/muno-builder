---
// src/components/templates/restaurant-dark/Testimonials.astro

// استقبال حقل التقييمات والمراجعات ديناميكياً من الباكيند عبر الـ Props
const { section_title, reviews } = Astro.props;

// بيانات تجريبية فاخرة بالألمانية كـ Fallback في حال كانت قاعدة البيانات فارغة
const defaultReviews = [
  {
    name: "Maximilian Weber",
    text: "Ein absolutes Meisterwerk der Kulinarik. Jedes Gericht erzählt eine eigene Geschichte. Der Service ist makellos und die Atmosphäre intim und exklusiv.",
    stars: 5,
    detail: "Guide Michelin 2026"
  },
  {
    name: "Dr. Sabine Schmidt",
    text: "Hervorragende Geschmackskompositionen und eine weitreichende Weinkarte. Die Liebe zum Detail ist in jedem Bissen spürbar. Ein Muss für Genießer.",
    stars: 5,
    detail: "Stammgast seit 2022"
  },
  {
    name: "Elena Rostova",
    text: "Ein unvergesslicher Abend. Das Tasting-Menü hat unsere Erwartungen weit übertroffen. Die Kombination aus regionalen Zutaten und moderner Technik ist genial.",
    stars: 5,
    detail: "Gastro-Kritikerin"
  }
];

// دمج المراجعات القادمة من Strapi v5 أو استخدام الافتراضية لحماية الموقع من الانهيار
const displayReviews = reviews && reviews.length > 0 ? reviews : defaultReviews;

// قائمة الصحف والمجلات الفاخرة التي ظهر فيها المطعم بالترجمة الألمانية الفخمة
const pressMentions = ["Die Zeit", "Süddeutsche Zeitung", "Der Spiegel", "Vogue Living", "Feinschmecker Magazin"];
---

<section class="py-28 lg:py-36 relative overflow-hidden bg-[#0E0B09]">
  
  <!-- Large decorative quote mark بالـ Tailwind -->
  <div class="absolute top-16 left-8 lg:left-16 select-none pointer-events-none font-serif text-[clamp(12rem,25vw,22rem)] color text-[#C8973A]/[0.04] leading-none font-bold">
    "
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10">
    
    <!-- رأس السكشن / Header -->
    <div class="flex items-center gap-4 mb-16 lg:mb-20">
      <div class="h-px w-8 bg-[#C8973A]" />
      <span class="uppercase tracking-[0.3em] text-[#C8973A] text-[0.58rem] font-medium">
        {section_title || "Stimmen unserer Gäste"}
      </span>
    </div>

    <!-- شبكة عرض التقييمات والفواصل بالـ Tailwind النقي -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-0">
      {displayReviews.map((t: any, i: number) => (
        <article
          class={`px-0 py-10 lg:py-0 border-t border-[#F2EDE4]/7 lg:border-t-0 ${
            i > 0 ? 'lg:border-l lg:border-[#F2EDE4]/7 lg:pl-10' : 'lg:pl-0'
          }`}
        >
          <div class={i === 0 ? 'lg:pl-0' : ''}>
            
            <!-- رسم النجوم التقييمية الذهبية تالياً لعدد النجوم المكتوب في الباكيند -->
            <div class="text-[#C8973A] text-xs tracking-wider flex gap-0.5">
              {Array.from({ length: t.stars || t.rating || 5 }).map(() => (
                <svg xmlns="http://w3.org" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5">
                  <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
                </svg>
              ))}
            </div>

            <!-- مقتبس التقييم الفاخر المتجاوب والناعم -->
            <blockquote class="my-8 font-serif text-[clamp(1.1rem,1.8vw,1.35rem)] text-[#F2EDE4] font-light leading-relaxed italic tracking-tight">
              "{t.text || t.quote}"
            </blockquote>

            <!-- خط فاصل رمادي شفاف -->
            <div class="h-px mb-6 bg-[#F2EDE4]/8" />

            <!-- بيانات العميل والتفاصيل الجانبية -->
            <div class="space-y-1 text-left">
              <div class="text-[#F2EDE4] text-sm font-medium tracking-wide">
                {t.name}
              </div>
              <div class="text-[#F2EDE4]/35 text-[0.7rem] tracking-wider font-light">
                {t.detail || "Geprüfter Gast"}
              </div>
            </div>
            
          </div>
        </article>
      ))}
    </div>

    <!-- قسم الظهور في الصحافة الألمانية الفخم / Press Mentions -->
    <div class="mt-24 pt-12 flex flex-col lg:flex-row items-center gap-8 lg:gap-16 border-t border-[#F2EDE4]/7">
      <span class="text-[#F2EDE4]/25 text-[0.58rem] tracking-[0.28em] uppercase whitespace-nowrap font-medium">
        Bekannt aus
      </span>
      <div class="flex flex-wrap justify-center lg:justify-start items-center gap-6 sm:gap-10 lg:gap-16 w-full lg:w-auto">
        {pressMentions.map((pub) => (
          <span class="text-[#F2EDE4]/20 text-sm font-light italic font-serif tracking-wide whitespace-nowrap hover:text-[#C8973A]/40 transition-colors duration-300">
            {pub}
          </span>
        ))}
      </div>
    </div>

  </div>
</section>
