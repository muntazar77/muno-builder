---
// src/components/OpeningHours.astro
const hours = [
  { day: "Montag", time: "Geschlossen", status: "closed" },
  { day: "Dienstag", time: "18:00 - 23:00", status: "open" },
  { day: "Mittwoch", time: "18:00 - 23:00", status: "open" },
  { day: "Donnerstag", time: "18:00 - 23:00", status: "open" },
  { day: "Freitag", time: "17:30 - 00:00", status: "open" },
  { day: "Samstag", time: "17:30 - 00:00", status: "open" },
  { day: "Sonntag", time: "12:00 - 22:00", status: "open" }
];

// دالة ذكية لتحديد اليوم الحالي أوتوماتيكياً وإضاءته للألمان لراحة المستخدم
const daysConfig: Record<number, string> = {
  0: "Sonntag", 1: "Montag", 2: "Dienstag", 3: "Mittwoch", 
  4: "Donnerstag", 5: "Freitag", 6: "Samstag"
};
const todayName = daysConfig[new Date().getDay()];
---
<section id="hours" class="py-28 lg:py-36 bg-[#0C0A08] relative overflow-hidden">
  
  <div class="absolute right-0 top-1/2 -translate-y-1/2 pointer-events-none select-none font-serif text-[clamp(10rem,20vw,18rem)] text-[#C8973A]/[0.015] leading-none font-bold italic pr-8">
    Offen
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
      
      <!-- الجانب الأيسر / Left Text -->
      <div class="lg:col-span-5">
        <div class="flex items-center gap-4 mb-8">
          <div class="h-px w-8 bg-[#C8973A]" />
          <span class="uppercase tracking-widest text-[#C8973A] text-[0.58rem] tracking-[0.3em]">
            Öffnungszeiten
          </span>
        </div>
        <h2 class="text-[#F2EDE4] mb-8 font-serif font-light text-[clamp(2.5rem,5vw,4.5rem)] leading-none tracking-tight">
          Planen Sie<br />
          <span class="italic font-semibold text-[#C8973A]">Ihren Besuch.</span>
        </h2>
        <p class="text-[#F2EDE4]/45 text-sm font-light leading-relaxed max-w-[36ch]">
          Wir empfehlen Ihnen, Ihren Tisch im Voraus zu reservieren. Spontane Besuche sind je nach Verfügbarkeit möglich, können jedoch nicht garantiert werden.
        </p>
        
        <div class="mt-10 p-6 bg-[#161310] border border-[#C8973A]/15">
          <div class="text-[0.55rem] tracking-[0.26em] uppercase text-[#C8973A] mb-3 font-medium">Letzte Bestellung</div>
          <div class="font-serif text-2xl text-[#F2EDE4] font-light leading-none">90 Minuten</div>
          <p class="text-[#F2EDE4]/40 text-xs font-light leading-relaxed mt-2">vor Küchenschluss.</p>
        </div>
      </div>

      <!-- جدول المواعيد الاحترافي / Hours table -->
      <div class="lg:col-span-7 flex flex-col justify-center">
        <div class="border-t border-[#F2EDE4]/10">
          {hours.map((row) => {
            const isToday = row.day === todayName;
            return (
              <div class={`flex items-center justify-between py-5 border-b border-[#F2EDE4]/10 px-4 transition-colors duration-150 ${isToday ? 'bg-[#C8973A]/[0.04]' : 'bg-transparent'}`}>
                <div class="flex items-center gap-4">
                  {isToday && <span class="w-1.5 h-1.5 rounded-full bg-[#C8973A]" />}
                  <span class={`font-serif text-[1.05rem] ${isToday ? 'font-medium text-[#F2EDE4]' : 'font-light text-[#F2EDE4]/55'} ${isToday ? 'ml-0' : 'ml-5'}`}>
                    {row.day}
                  </span>
                  {isToday && (
                    <span class="px-2 py-0.5 bg-[#C8973A]/12 border border-[#C8973A]/25 text-[#C8973A] text-[0.5rem] tracking-[0.22em] uppercase font-semibold">
                      Heute
                    </span>
                  )}
                </div>
                {row.status === "closed" ? (
                  <span class="text-[#F2EDE4]/20 text-[0.72rem] tracking-[0.16em] uppercase font-normal">Geschlossen</span>
                ) : (
                  <span class={`font-serif text-sm ${isToday ? 'text-[#C8973A] font-normal' : 'text-[#F2EDE4]/50 font-light'}`}>
                    {row.time}
                  </span>
                )}
              </div>
            );
          })}
        </div>
        <p class="mt-6 text-[#F2EDE4]/30 text-xs font-light leading-relaxed pl-4">
          * Die Küche schließt 45 minutes vor Apfelschluss. Die Bar bleibt bis zur angegebenen Schließzeit geöffnet.
        </p>
      </div>

    </div>
  </div>
</section>
