---
// src/components/Header.astro
// استقبال الحقول الحية من مصنع المكونات RenderSections
const { clientName = "Mono Client", templateName = "luxury", headerLinks = [] } = Astro.props;

// 💡 تحديد الألوان بصورة ديناميكية صارمة بناءً على القالب المختار للعميل
const isLuxury = templateName === 'luxury';
const textColor = isLuxury ? 'text-[#F2EDE4]' : 'text-gray-900';
const textMutedColor = isLuxury ? 'text-[#F2EDE4]/55 hover:text-[#F2EDE4]' : 'text-gray-600 hover:text-black';
const mobileMenuBg = isLuxury ? 'bg-[#0C0A08]/97' : 'bg-white/98';
---
<header 
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent"
  data-template={templateName}
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="flex items-center justify-between h-20 lg:h-24">
      
      <!-- الشعار / Logo -->
      <a href="#" class="flex flex-col leading-none font-serif no-underline">
        <span class="text-[0.55rem] tracking-[0.3em] uppercase text-[#C8973A] mb-1">
          Est. 2008
        </span>
        <span class={`text-2xl font-medium tracking-tight sm:text-3xl transition-colors duration-300 ${textColor}`}>
          {clientName}
        </span>
      </a>

      <!-- 💡 السحر البرمجي: رندرة القائمة لمتصفح الكمبيوتر ديناميكياً من الباكيند -->
      <nav class="hidden lg:flex items-center gap-10">
        {headerLinks && headerLinks.length > 0 ? (
          headerLinks.map((link: any) => (
            <a 
              href={link.url || "#"} 
              class={`text-[0.7rem] font-medium tracking-[0.18em] uppercase transition-colors duration-300 no-underline ${textMutedColor}`}
            >
              {link.label}
            </a>
          ))
        ) : (
          /* قيم أمان افتراضية في حال كانت المصفوفة فارغة في Strapi */
          <a href="#menu" class={`text-[0.7rem] font-medium tracking-[0.18em] uppercase no-underline ${textMutedColor}`}>Speisekarte</a>
          <a href="#contact" class={`text-[0.7rem] font-medium tracking-[0.18em] uppercase no-underline ${textMutedColor}`}>Kontakt</a>
        )}
      </nav>

      <!-- زر الحجز للكمبيوتر / Reserve CTA -->
      <div class="hidden lg:flex items-center gap-6">
        <a 
          href="#reservation" 
          class="px-7 py-2.5 text-[0.65rem] font-semibold tracking-[0.22em] uppercase border border-[#C8973A] text-[#C8973A] hover:bg-[#C8973A] hover:text-[#0C0A08] transition-all duration-300 no-underline"
        >
          Tisch reservieren
        </a>
      </div>

      <!-- زر الموبايل / Mobile Hamburger Button -->
      <button 
        id="menu-toggle"
        class={`lg:hidden p-2 focus:outline-none ${textColor}`} 
        aria-label="Menü öffnen"
      >
        <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>

    </div>
  </div>

  <!-- 💡 قائمة الموبايل الديناميكية المتوافقة مع ألوان القوالب مئة بالمئة -->
  <div id="mobile-menu" class={`hidden lg:hidden border-t border-[#F2EDE4]/10 shadow-lg ${mobileMenuBg}`}>
    <nav class="flex flex-col px-6 py-8 gap-6">
      {headerLinks && headerLinks.map((link: any) => (
        <a 
          href={link.url || "#"} 
          class={`text-[0.8rem] tracking-[0.2em] uppercase py-2 border-b border-gray-100/10 no-underline ${textColor}`}
        >
          {link.label}
        </a>
      ))}
      <a href="#reservation" class="mt-4 py-3 text-center text-xs tracking-[0.2em] uppercase border border-[#C8973A] text-[#C8973A] no-underline">
        Tisch reservieren
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const isLuxury = header?.getAttribute('data-template') === 'luxury';

  // حساب حركة السكرول لتغيير الخلفية بذكاء لثيم الـ Light والـ Dark
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.remove('bg-transparent');
      if (isLuxury) {
        header?.classList.add('bg-[#0C0A08]/88', 'backdrop-blur-md', 'border-b', 'border-[#F2EDE4]/10');
      } else {
        header?.classList.add('bg-white/90', 'backdrop-blur-md', 'border-b', 'border-gray-200', 'shadow-sm');
      }
    } else {
      header?.classList.remove('bg-[#0C0A08]/88', 'bg-white/90', 'backdrop-blur-md', 'border-b', 'border-[#F2EDE4]/10', 'border-gray-200', 'shadow-sm');
      header?.classList.add('bg-transparent');
    }
  });

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
