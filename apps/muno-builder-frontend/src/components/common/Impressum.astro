---
// src/components/common/Impressum.astro
interface Props {
  data: {
    company_name: string;
    owner_name: string;
    street_address: string;
    zip_code: string;
    city: string;
    phone_number: string;
    email_address: string;
    ust_id?: string;
    register_court?: string;
    register_number?: string;
  };
}

const { data } = Astro.props;
---
<section class="max-w-4xl mx-auto px-6 py-16 bg-white text-gray-800 antialiased font-sans">
  <h1 class="text-3xl font-extrabold text-gray-900 border-b pb-4 mb-6">Impressum</h1>
  
  <div class="space-y-6 text-sm leading-relaxed">
    <!-- 1. Angaben gemäß § 5 TMG -->
    <div>
      <h2 class="text-lg font-bold text-gray-900 mb-2">Angaben gemäß § 5 TMG</h2>
      <p class="font-semibold text-base text-brand-primary">{data.company_name}</p>
      <p>{data.street_address}</p>
      <p>{data.zip_code} {data.city}</p>
    </div>

    <!-- 2. Vertreten durch -->
    <div>
      <h2 class="text-base font-bold text-gray-950 mb-1">Vertreten durch:</h2>
      <p>{data.owner_name}</p>
    </div>

    <!-- 3. Kontakt -->
    <div>
      <h2 class="text-lg font-bold text-gray-900 mb-2">Kontakt</h2>
      <p><span class="font-medium">Telefon:</span> {data.phone_number}</p>
      <p><span class="font-medium">E-Mail:</span> <a href={`mailto:${data.email_address}`} class="text-blue-600 hover:underline">{data.email_address}</a></p>
    </div>

    <!-- 4. Registereintrag (اختياري للشركات المسجلة القانونية) -->
    {(data.register_court || data.register_number) && (
      <div>
        <h2 class="text-lg font-bold text-gray-900 mb-2">Registereintrag</h2>
        <p>Eintragung im Handelsregister.</p>
        <p><span class="font-medium">Registergericht:</span> {data.register_court || 'N/A'}</p>
        <p><span class="font-medium">Registernummer:</span> {data.register_number || 'N/A'}</p>
      </div>
    )}

    <!-- 5. Umsatzsteuer-ID (إلزامي في حال وجود رقم ضريبي تجاري) -->
    {data.ust_id && (
      <div>
        <h2 class="text-lg font-bold text-gray-900 mb-2">Umsatzsteuer-ID</h2>
        <p>Umsatzsteuer-Identifikationsnummer gemäß § 27 a Umsatzsteuergesetz:</p>
        <p class="font-mono bg-gray-50 px-2 py-1 rounded inline-block text-gray-700 mt-1 border border-gray-200">{data.ust_id}</p>
      </div>
    )}

    <!-- 6. EU-Streitschlichtung المادة الإلزامية للمواقع التجارية في أوروبا -->
    <div class="border-t pt-4 mt-8 text-xs text-gray-500">
      <h3 class="font-bold text-gray-700 mb-1">EU-Streitschlichtung</h3>
      <p>Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit: 
        <a href="https://europa.eu" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline">https://europa.eu</a>.
        Unsere E-Mail-Adresse finden Sie oben im Impressum.
      </p>
    </div>
  </div>
</section>
