---
// src/components/QRCodeSection.astro
import QRCode from 'qrcode';

const { restaurantSlug, restaurantName = "Unser Restaurant" } = Astro.props;

// بناء الرابط الحقيقي الذي سيفتحه الـ QR Code (محلياً وفي المستقبل الدومين الحقيقي)
const menuUrl = `http://localhost:4321/${restaurantSlug}`;

// توليد الـ QR Code على شكل Data URL (Image base64) مباشرة داخل السيرفر أثناء الرندر
let qrCodeImage = '';
try {
  qrCodeImage = await QRCode.toDataURL(menuUrl, {
    margin: 2,
    width: 300,
    color: {
      dark: '#0f172a',  // لون المربعات (رمادي غامق جداً قريب للأسود)
      light: '#ffffff' // الخلفية بيضاء
    }
  });
} catch (err) {
  console.error('🚨 Fehler beim Erzeugen des QR-Codes:', err);
}
---

<section class="py-20 px-6 bg-gray-50 text-gray-800 border-t border-gray-100">
  <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    
    <!-- الجانب الأيسر: النصوص والشرح بالألمانية -->
    <div class="space-y-6 text-left">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-amber-50 border border-amber-200 text-amber-700 rounded-full text-xs font-bold uppercase tracking-wider">
        Kontaktloses Erlebnis
      </div>
      <h3 class="text-2xl md:text-4xl font-black text-gray-900 tracking-tight">
        Unsere digitale QR-Speisekarte
      </h3>
      <p class="text-gray-600 text-sm md:text-base leading-relaxed">
        Scannen Sie den QR-Code mit Ihrer Smartphone-Kamera, um direkt auf unsere aktuelle Speisekarte zuzugreifen. Keine App-Installation notwendig – schnell, hygienisch und umweltfreundlich.
      </p>
      
      <!-- زر تجميلي للطباعة -->
      <button 
        onclick="window.print()" 
        class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-bold px-6 py-3 rounded-xl transition duration-300 text-sm shadow-sm cursor-pointer border-none"
      >
        <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h-11.32" /></svg>
        Code für Tische ausdrucken
      </button>
    </div>

    <!-- الجانب الأيمن: برواز عرض الـ QR Code الفاخر -->
    <div class="flex justify-center">
      <div class="bg-white p-8 rounded-3xl shadow-md border border-gray-100 text-center space-y-4 max-w-[280px] sm:max-w-xs transition-transform duration-300 hover:scale-102">
        <div class="border-4 border-amber-500 p-2 rounded-2xl bg-white aspect-square">
          {qrCodeImage ? (
            <img src={qrCodeImage} alt={`QR Code für ${restaurantName}`} class="w-full h-full object-contain" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-red-500 text-xs">QR-Code Fehler</div>
          )}
        </div>
        <div>
          <h4 class="font-bold text-gray-900 text-base">{restaurantName}</h4>
          <p class="text-xs text-gray-400 mt-1">Scannen zum Genießen</p>
        </div>
      </div>
    </div>

  </div>
</section>
